<% layout("/layouts/boilerplate") %>

<section class="error-page">
    <div class="error-card">
        <div class="error-illustration">
            <div class="error-icon-circle">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
        </div>

        <div class="error-copy">
            <span class="error-badge">Error <%= statusCode %></span>
            <h1>Page not found</h1>
            <p class="error-message-text"><%= message %></p>

            <div class="error-actions">
                <a href="/" class="btn-primary">Back to Home</a>
                <a href="/listings" class="btn-secondary">Browse Listings</a>
            </div>

            <p class="error-help">If this keeps happening, please refresh or try again later.</p>
        </div>
    </div>
</section>