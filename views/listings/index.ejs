<% layout("/layouts/boilerplate") %>
    <div class="listings-page">
        <!-- Page Header -->
        <div class="listings-header">
            <div class="listings-header-content">
                <div class="filters listings-filters">
                    <div class="filter">
                        <div class="icon"><i class="fa-solid fa-hotel"></i></div>
                        <p>Hotels</p>
                    </div>
                    <div class="filter">
                        <div class="icon"><i class="fa-solid fa-fire"></i></div>
                        <p>Trending</p>
                    </div>
                    <div class="filter">
                        <div class="icon"><i class="fa-solid fa-mountain-city"></i></div>
                        <p>Villa</p>
                    </div>
                    <div class="filter f-hidden">
                        <div class="icon"><i class="fa-solid fa-mountain"></i></div>
                        <p>Mountains</p>
                    </div>
                    <div class="filter f-hidden f-show">
                        <div class="icon"><i class="fa-solid fa-house-flag"></i></div>
                        <p>Camp House</p>
                    </div>
                    <div class="filter f-hidden f-show">
                        <div class="icon"><i class="fa-solid fa-cow"></i></div>
                        <p>Farms</p>
                    </div>
                    <div class="filter">
                        <div class="icon"><i class="fa-solid fa-campground"></i></div>
                        <p>Campaign</p>
                    </div>
                    <div class="filter">
                        <div class="icon"><i class="fa-solid fa-snowflake"></i></div>
                        <p>Arctic</p>
                    </div>
                    <div class="filter">
                        <div class="icon"><i class="fa-solid fa-bed"></i></div>
                        <p>Rooms</p>
                    </div>
                    <div class="filter f-hidden">
                        <div class="icon"><i class="fa-solid fa-landmark-dome"></i></div>
                        <p>Cabin</p>
                    </div>
                    <div class="filter f-hidden">
                        <div class="icon"><i class="fa-solid fa-sailboat"></i></div>
                        <p>Boat</p>
                    </div>

                    <div class="tax-toggle">
                        <div class="form-check-reverse form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                            <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
                        </div>
                    </div>

                </div>

                <div class="listings-filters">
                    <button class="filter-btn active" data-filter="all">All Listings</button>
                    <button class="filter-btn" data-filter="popular">Popular</button>
                    <button class="filter-btn" data-filter="newest">Newest</button>
                    <button class="filter-btn" data-filter="budget">Budget Friendly</button>
                </div>
            </div>
        </div>

        <!-- Listings Grid -->
        <div class="listings-container">
            <% if(allListings.length> 0) { %>
                <div class="listings-grid">
                    <% for(let listing of allListings){ %>
                        <a href="/listings/<%= listing._id %>" class="listing-card">
                            <div class="listing-image-wrapper">
                                <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="listing-image">
                                <div class="listing-badge">Featured</div>
                                <button class="wishlist-btn" type="button">
                                    <i class="fa-regular fa-heart"></i>
                                </button>
                            </div>
                            <div class="listing-content">
                                <div class="listing-header">
                                    <h3 class="listing-title">
                                        <%= listing.title %>
                                    </h3>
                                    <div class="listing-rating">
                                        <i class="fa-solid fa-star"></i>
                                        <span>4.8</span>
                                    </div>
                                </div>
                                <p class="listing-location">
                                    <i class="fa-solid fa-location-dot"></i>
                                    <%= listing.location %>
                                </p>
                                <div class="listing-amenities">
                                    <span class="amenity"><i class="fa-solid fa-bed"></i>
                                        <%= listing.bedrooms || 1 %> Bed<%= (listing.bedrooms || 1)> 1 ? 's' : '' %>
                                    </span>
                                    <span class="amenity"><i class="fa-solid fa-bath"></i>
                                        <%= listing.bathrooms || 1 %> Bath<%= (listing.bathrooms || 1)> 1 ? 's' : '' %>
                                    </span>
                                    <% if(listing.amenities && listing.amenities.includes('wifi')) { %>
                                        <span class="amenity"><i class="fa-solid fa-wifi"></i> WiFi</span>
                                        <% } else if(listing.amenities && listing.amenities.length> 0) { %>
                                            <span class="amenity"><i class="fa-solid fa-concierge-bell"></i>
                                                <%= listing.amenities.length %> Amenities
                                            </span>
                                            <% } else { %>
                                                <span class="amenity"><i class="fa-solid fa-home"></i> Cozy</span>
                                                <% } %>
                                </div>
                                <div class="listing-footer">
                                    <div class="listing-price">
                                        <span class="price-amount">&#8377; <%= listing.price.toLocaleString("en-IN") %>
                                                </span>
                                        <span class="price-period">/ night <i class="tax-info"> &nbsp; +18%
                                                GST</i></span>
                                    </div>
                                    <button class="view-btn" type="button">View Details</button>
                                </div>
                            </div>
                        </a>
                        <% } %>
                </div>
                <% } else { %>
                    <div class="empty-state">
                        <div class="empty-icon">
                            <i class="fa-solid fa-inbox"></i>
                        </div>
                        <h3>No listings found</h3>
                        <p>There are no listings available at the moment.</p>
                        <a href="/listings/new" class="btn-primary">Create Your First Listing</a>
                    </div>
                    <% } %>
        </div>
    </div>