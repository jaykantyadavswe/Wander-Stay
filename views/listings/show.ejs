<% layout("/layouts/boilerplate") %>

    <div class="listing-details-page">
        <!-- Enhanced Hero Section with Image Gallery -->
        <div class="listing-hero">
            <div class="gallery-container">
                <!-- Main Image -->
                <div class="gallery-main">
                    <img id="mainImage" src="<%= listing.image.url %>" alt="<%= listing.title %>" class="main-image">
                    <div class="gallery-overlay">
                        <button class="gallery-nav prev" onclick="changeImage(-1)" type="button">
                            <i class="fa-solid fa-chevron-left"></i>
                        </button>
                        <button class="gallery-nav next" onclick="changeImage(1)" type="button">
                            <i class="fa-solid fa-chevron-right"></i>
                        </button>
                        <button class="wishlist-icon" type="button" onclick="toggleWishlist()">
                            <i class="fa-regular fa-heart"></i>
                        </button>
                        <button class="share-icon" type="button" onclick="shareProperty()">
                            <i class="fa-solid fa-share-nodes"></i>
                        </button>
                    </div>

                    <!-- Image Counter -->
                    <div class="image-counter">
                        <span id="imageNumber">1</span>/<span id="totalImages">4</span>
                    </div>
                </div>

                <!-- Thumbnail Gallery -->
                <div class="gallery-thumbnails">
                    <button class="thumbnail-item active" onclick="selectImage(0)" type="button">
                        <img src="<%= listing.image.url %>" alt="Gallery image 1" class="thumbnail-img">
                        <div class="thumbnail-overlay"></div>
                    </button>
                    <button class="thumbnail-item" onclick="selectImage(1)" type="button">
                        <img src="<%= listing.image.url %>" alt="Gallery image 2" class="thumbnail-img"
                            style="object-position: center top;">
                        <div class="thumbnail-overlay"></div>
                    </button>
                    <button class="thumbnail-item" onclick="selectImage(2)" type="button">
                        <img src="<%= listing.image.url %>" alt="Gallery image 3" class="thumbnail-img"
                            style="object-position: center bottom;">
                        <div class="thumbnail-overlay"></div>
                    </button>
                    <button class="thumbnail-item" onclick="selectImage(3)" type="button">
                        <img src="<%= listing.image.url %>" alt="Gallery image 4" class="thumbnail-img"
                            style="object-position: right center;">
                        <div class="thumbnail-overlay"></div>
                        <div class="thumbnail-badge">+4</div>
                    </button>
                </div>
            </div>
        </div>

        <div class="listing-container">
            <!-- Main Content -->
            <div class="listing-main">
                <!-- Title & Header -->
                <div class="listing-title-section">
                    <div>
                        <h1 class="property-title">
                            <%= listing.title %>
                        </h1>
                        <div class="listing-meta">
                            <span class="rating">
                                <i class="fa-solid fa-star"></i>
                                <%= listing.averageRating = 4.5 %> (<%= listing.reviewCount = 5 %> reviews)
                            </span>
                            <span class="location-tag">
                                <i class="fa-solid fa-location-dot"></i>
                                <%= listing.location %>, <%= listing.country %>
                            </span>
                            <span class="location-tag">
                                <i class="fa-solid fa-user"></i>
                                Owned by : <%= listing.owner.username %>
                            </span>
                        </div>
                    </div>
                    <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
                        <div class="action-buttons">
                            <a href="/listings/<%= listing._id %>/edit" class="btn-secondary">
                                <i class="fa-solid fa-pen"></i> Edit
                            </a>
                            <form action="/listings/<%= listing._id %>?_method=DELETE" method="post"
                                class="delete-form">
                                <button type="submit" class="btn-danger" onclick="return confirm('Are you sure?')">
                                    <i class="fa-solid fa-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                        <% } %>
                </div>

                <!-- Description -->
                <div class="section description-section">
                    <h2 class="section-title">About this place</h2>
                    <p class="description-text">
                        <%= listing.description %>
                    </p>
                </div>

                <!-- Amenities -->
                <div class="section amenities-section">
                    <h2 class="section-title">What this place offers</h2>
                    <div class="amenities-grid">
                        <% if(listing.amenities && listing.amenities.length> 0) { %>
                            <% listing.amenities.forEach(amenity=> { %>
                                <div class="amenity-item">
                                    <% if(amenity==='wifi' ) { %>
                                        <i class="fa-solid fa-wifi"></i>
                                        <div>
                                            <h4>WiFi</h4>
                                            <p>High-speed internet</p>
                                        </div>
                                        <% } else if(amenity==='kitchen' ) { %>
                                            <i class="fa-solid fa-kitchen-set"></i>
                                            <div>
                                                <h4>Kitchen</h4>
                                                <p>Full equipped</p>
                                            </div>
                                            <% } else if(amenity==='parking' ) { %>
                                                <i class="fa-solid fa-car"></i>
                                                <div>
                                                    <h4>Parking</h4>
                                                    <p>Free parking</p>
                                                </div>
                                                <% } else if(amenity==='pool' ) { %>
                                                    <i class="fa-solid fa-swimming-pool"></i>
                                                    <div>
                                                        <h4>Pool</h4>
                                                        <p>Swimming pool</p>
                                                    </div>
                                                    <% } else if(amenity==='gym' ) { %>
                                                        <i class="fa-solid fa-dumbbell"></i>
                                                        <div>
                                                            <h4>Gym</h4>
                                                            <p>Fitness center</p>
                                                        </div>
                                                        <% } else if(amenity==='ac' ) { %>
                                                            <i class="fa-solid fa-fan"></i>
                                                            <div>
                                                                <h4>Air Conditioning</h4>
                                                                <p>Climate control</p>
                                                            </div>
                                                            <% } else if(amenity==='tv' ) { %>
                                                                <i class="fa-solid fa-tv"></i>
                                                                <div>
                                                                    <h4>Smart TV</h4>
                                                                    <p>Streaming ready</p>
                                                                </div>
                                                                <% } else if(amenity==='washer' ) { %>
                                                                    <i class="fa-solid fa-shirt"></i>
                                                                    <div>
                                                                        <h4>Washer</h4>
                                                                        <p>Laundry facilities</p>
                                                                    </div>
                                                                    <% } %>
                                </div>
                                <% }); %>
                                    <% } else { %>
                                        <div class="amenity-item">
                                            <i class="fa-solid fa-wifi"></i>
                                            <div>
                                                <h4>WiFi</h4>
                                                <p>High-speed internet</p>
                                            </div>
                                        </div>
                                        <div class="amenity-item">
                                            <i class="fa-solid fa-kitchen-set"></i>
                                            <div>
                                                <h4>Kitchen</h4>
                                                <p>Full equipped</p>
                                            </div>
                                        </div>
                                        <div class="amenity-item">
                                            <i class="fa-solid fa-car"></i>
                                            <div>
                                                <h4>Parking</h4>
                                                <p>Free parking</p>
                                            </div>
                                        </div>
                                        <div class="amenity-item">
                                            <i class="fa-solid fa-fan"></i>
                                            <div>
                                                <h4>Air Conditioning</h4>
                                                <p>Climate control</p>
                                            </div>
                                        </div>
                                        <% } %>
                    </div>
                </div>

                <!-- Room Details -->
                <div class="section room-details-section">
                    <h2 class="section-title">Room Details</h2>
                    <div class="details-grid">
                        <div class="detail-item">
                            <span class="detail-label">Bedrooms</span>
                            <span class="detail-value">
                                <%= listing.bedrooms || 1 %>
                            </span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Bathrooms</span>
                            <span class="detail-value">
                                <%= listing.bathrooms || 1 %>
                            </span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Guests</span>
                            <span class="detail-value">
                                <%= listing.maxGuests || 2 %>
                            </span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Area</span>
                            <span class="detail-value">
                                <%= listing.area || 500 %> <span class="sqft">sq.ft</span>
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Reviews Section -->
                <div class="section reviews-section">
                    <h2 class="section-title">Guest Reviews</h2>
                    <div class="reviews-container">
                        <% if(listing.reviews && listing.reviews.length> 0) { %>
                            <% listing.reviews.forEach(review=> { %>
                                <div class="review-card">
                                    <div class="review-header">
                                        <div class="reviewer-info">
                                            <div class="reviewer-avatar">
                                                <%= review.author.username.charAt(0).toUpperCase() %>
                                            </div>
                                            <div>
                                                <h4>
                                                    <%= review.author.username %>
                                                </h4>
                                                <p>
                                                    <%= new Date(review.createdAt).toLocaleDateString('en-US', {
                                                        year: 'numeric' , month: 'long' , day: 'numeric' }) %>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="review-rating">
                                            <% for(let i=1; i <=5; i++) { %>
                                                <% if(i <= review.rating) { %>
                                                    <i class="fa-solid fa-star"></i>
                                                    <% } else { %>
                                                        <i class="fa-regular fa-star"></i>
                                                        <% } %>
                                                            <% } %>
                                                                <span>
                                                                    <%= review.rating %>
                                                                </span>
                                        </div>
                                    </div>
                                    <p class="review-text">
                                        <%= review.comment %>
                                    </p>
                                    <div class="review-actions">
                                        <form
                                            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                            method="post" class="delete-review-form">
                                            <button type="submit" class="btn-link delete-review-btn"
                                                onclick="return confirm('Are you sure you want to delete this review?')">
                                                <i class="fa-solid fa-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                <% }); %>
                                    <% } else { %>
                                        <div class="no-reviews">
                                            <i class="fa-solid fa-comments"></i>
                                            <h3>No reviews yet</h3>
                                            <p>Be the first to leave a review for this listing!</p>
                                        </div>
                                        <% } %>
                    </div>
                </div>
                <!-- Write Review Form -->
                <% if(currUser){ %>
                <div class="section review-form-section">
                    <h2 class="section-title">Write a Review</h2>
                    <form action="/listings/<%= listing._id %>/reviews" method="POST" class="review-form">
                        <div class="form-group">
                            <!-- <label for="reviewerName">Your Name *</label>
                            <input type="text" name="review[author]" id="reviewerName" class="form-input"
                                placeholder="Enter your name" required>
                            <br> -->
                            <label for="reviewerEmail">Your Email *</label>
                            <input type="text" name="review[email]" id="reviewerEmail" class="form-input"
                                placeholder="Enter your email" required>
                        </div>

                        <div class="form-group">
                            <label>Rating *</label>
                            <div class="rating-input">
                                <div class="stars" id="ratingStars">
                                    <i class="fa-regular fa-star" data-rating="1"></i>
                                    <i class="fa-regular fa-star" data-rating="2"></i>
                                    <i class="fa-regular fa-star" data-rating="3"></i>
                                    <i class="fa-regular fa-star" data-rating="4"></i>
                                    <i class="fa-regular fa-star" data-rating="5"></i>
                                </div>
                                <input type="hidden" name="review[rating]" id="ratingValue" value="1" required>
                                <span class="rating-text" id="ratingText">Select a rating</span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="reviewComment">Your Review *</label>
                            <textarea name="review[comment]" id="reviewComment" class="form-input review-textarea"
                                placeholder="Share your experience about this place..." rows="4" required></textarea>
                            <small class="form-help">Minimum 10 characters</small>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn-primary submit-review-btn">
                                <i class="fa-solid fa-paper-plane"></i> Submit Review
                            </button>
                            <button type="button" class="btn-secondary cancel-review-btn" onclick="cancelReview()">
                                Cancel
                            </button>
                        </div>
                    </form>
                </div>
                <% } %>

                <!-- Location Map -->
                <div class="section location-section">
                    <h2 class="section-title">Where you'll be</h2>
                    <div class="map-placeholder">
                        <i class="fa-solid fa-map"></i>
                        <p>Map will be displayed here</p>
                        <small>
                            <%= listing.location %>, <%= listing.country %>
                        </small>
                    </div>
                </div>
            </div>

            <!-- Sidebar - Booking Card -->
            <div class="listing-sidebar">
                <div class="booking-card">
                    <div class="price-section">
                        <span class="price">&#8377; <%= listing.price.toLocaleString("en-IN") %></span>
                        <span class="period">/night</span>
                    </div>

                    <div class="booking-form">
                        <div class="form-group">
                            <label>Check In</label>
                            <input type="date" class="form-input" placeholder="Add date">
                        </div>
                        <div class="form-group">
                            <label>Check Out</label>
                            <input type="date" class="form-input" placeholder="Add date">
                        </div>
                        <div class="form-group">
                            <label>Guests</label>
                            <select class="form-input">
                                <option>1 Guest</option>
                                <option>2 Guests</option>
                                <option>3 Guests</option>
                                <option>4 Guests</option>
                            </select>
                        </div>
                    </div>

                    <button class="btn-book" type="button" onclick="bookNow()">Book Now</button>

                    <div class="price-breakdown">
                        <div class="breakdown-item">
                            <span>&#8377; <%= listing.price.toLocaleString("en-IN") %> × 5 nights</span>
                            <span>&#8377; <%= (listing.price * 5).toLocaleString("en-IN") %></span>
                        </div>
                        <div class="breakdown-item">
                            <span>Service fee</span>
                            <span>&#8377; 2000</span>
                        </div>
                        <div class="breakdown-item total">
                            <span>Total before taxes</span>
                            <span>&#8377; <%= (listing.price * 5 + 2000).toLocaleString("en-IN") %></span>
                        </div>
                    </div>

                    <div class="host-info-card">
                        <h3>About the host</h3>
                        <div class="host-profile">
                            <div class="host-avatar">R</div>
                            <div>
                                <h4>Raj Patel</h4>
                                <p>Superhost</p>
                            </div>
                        </div>
                        <button class="btn-message" type="button">
                            <i class="fa-solid fa-message"></i> Message Host
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let currentImageIndex = 0;
        // Gallery images - can be extended to pull from database if needed
        const images = [
            '<%= listing.image.url %>',
            '<%= listing.image.url %>',
            '<%= listing.image.url %>',
            '<%= listing.image.url %>'
        ];

        // Initialize total images count
        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('totalImages').textContent = images.length;
        });

        function changeImage(direction) {
            currentImageIndex = (currentImageIndex + direction + images.length) % images.length;
            updateGallery();
        }

        function selectImage(index) {
            currentImageIndex = index;
            updateGallery();
        }

        function updateGallery() {
            // Update main image
            const mainImage = document.getElementById('mainImage');
            mainImage.style.opacity = '0';

            setTimeout(() => {
                mainImage.src = images[currentImageIndex];
                mainImage.style.opacity = '1';
            }, 150);

            // Update image counter
            document.getElementById('imageNumber').textContent = currentImageIndex + 1;

            // Update thumbnail selection
            document.querySelectorAll('.thumbnail-item').forEach((thumb, index) => {
                thumb.classList.toggle('active', index === currentImageIndex);
            });
        }

        function toggleWishlist() {
            const btn = document.querySelector('.wishlist-icon');
            btn.classList.toggle('active');

            // Haptic feedback for mobile
            if (navigator.vibrate) {
                navigator.vibrate(50);
            }
        }

        function shareProperty() {
            if (navigator.share) {
                navigator.share({
                    title: '<%= listing.title %>',
                    text: 'Check out this amazing property!',
                    url: window.location.href
                });
            } else {
                // Fallback for browsers that don't support share API
                alert('Share this property: ' + window.location.href);
            }
        }

        function bookNow() {
            alert('Booking feature coming soon!');
        }

        // Review Form Functionality
        document.addEventListener('DOMContentLoaded', function () {
            const stars = document.querySelectorAll('#ratingStars i');
            const ratingValue = document.getElementById('ratingValue');
            const ratingText = document.getElementById('ratingText');

            stars.forEach(star => {
                star.addEventListener('click', function () {
                    const rating = this.getAttribute('data-rating');
                    ratingValue.value = rating;

                    // Update star display
                    stars.forEach((s, index) => {
                        if (index < rating) {
                            s.className = 'fa-solid fa-star';
                        } else {
                            s.className = 'fa-regular fa-star';
                        }
                    });

                    // Update rating text
                    const ratingTexts = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];
                    ratingText.textContent = ratingTexts[rating];
                });

                star.addEventListener('mouseover', function () {
                    const rating = this.getAttribute('data-rating');
                    stars.forEach((s, index) => {
                        if (index < rating) {
                            s.className = 'fa-solid fa-star';
                        } else {
                            s.className = 'fa-regular fa-star';
                        }
                    });
                });
            });

            // Reset stars on mouse leave if no rating selected
            document.getElementById('ratingStars').addEventListener('mouseleave', function () {
                const currentRating = ratingValue.value;
                if (currentRating === '0') {
                    stars.forEach(s => s.className = 'fa-regular fa-star');
                    ratingText.textContent = 'Select a rating';
                } else {
                    stars.forEach((s, index) => {
                        if (index < currentRating) {
                            s.className = 'fa-solid fa-star';
                        } else {
                            s.className = 'fa-regular fa-star';
                        }
                    });
                }
            });
        });

        function cancelReview() {
            // Reset form
            document.querySelector('.review-form').reset();
            document.querySelectorAll('#ratingStars i').forEach(s => s.className = 'fa-regular fa-star');
            document.getElementById('ratingText').textContent = 'Select a rating';
            document.getElementById('ratingValue').value = '0';
        }

        // Keyboard navigation for gallery
        document.addEventListener('keydown', function (event) {
            if (event.key === 'ArrowLeft') {
                changeImage(-1);
            } else if (event.key === 'ArrowRight') {
                changeImage(1);
            }
        });

        // Style transitions
        const mainImage = document.getElementById('mainImage');
        if (mainImage) {
            mainImage.style.transition = 'opacity 0.3s ease-in-out';
        }
    </script>