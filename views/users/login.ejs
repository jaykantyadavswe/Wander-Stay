<style>
    *,
    *::before,
    *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root {
        --red: #e63946;
        --dark: #1a1a1a;
        --mid: #555;
        --light: #f7f7f7;
        --border: #e0e0e0;
        --white: #ffffff;
        --radius: 14px;
    }

    body {
        min-height: 100vh;
        display: flex;
        font-family: 'DM Sans', sans-serif;
        background: var(--light);
    }

    /* LEFT PANEL */
    .left {
        width: 45%;
        background: var(--dark);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 40px;
    }

    .left::before {
        content: '';
        position: absolute;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(230, 57, 70, 0.25) 0%, transparent 70%);
        top: -100px;
        left: -100px;
    }

    .left::after {
        content: '';
        position: absolute;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(230, 57, 70, 0.15) 0%, transparent 70%);
        bottom: -80px;
        right: -80px;
    }

    .left-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        z-index: 1;
    }

    .logo-icon {
        width: 38px;
        height: 38px;
        background: var(--white);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .logo-icon svg {
        width: 20px;
        height: 20px;
    }

    .logo-text {
        font-family: 'DM Sans', sans-serif;
        font-size: 20px;
        font-weight: 500;
        color: var(--white);
    }

    .logo-text span {
        color: var(--red);
    }

    .left-content {
        z-index: 1;
    }

    .left-content h1 {
        font-family: 'Playfair Display', serif;
        font-size: clamp(28px, 3vw, 42px);
        color: var(--white);
        line-height: 1.25;
        margin-bottom: 16px;
    }

    .left-content p {
        color: rgba(255, 255, 255, 0.55);
        font-size: 15px;
        line-height: 1.7;
        max-width: 300px;
    }

    .left-cards {
        display: flex;
        flex-direction: column;
        gap: 12px;
        z-index: 1;
    }

    .mini-card {
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        backdrop-filter: blur(8px);
    }

    .mini-card-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        background: rgba(230, 57, 70, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .mini-card-text p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.8);
        font-weight: 500;
    }

    .mini-card-text span {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.4);
    }

    /* RIGHT PANEL */
    .right {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 24px;
    }

    .form-box {
        width: 100%;
        max-width: 420px;
    }

    .form-box h2 {
        font-family: 'Playfair Display', serif;
        font-size: 28px;
        color: var(--dark);
        margin-bottom: 6px;
    }

    .form-box .subtitle {
        font-size: 14px;
        color: var(--mid);
        margin-bottom: 32px;
    }

    .form-box .subtitle a {
        color: var(--red);
        text-decoration: none;
        font-weight: 500;
    }

    .field {
        margin-bottom: 18px;
    }

    .field label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: var(--dark);
        margin-bottom: 7px;
    }

    .input-wrap {
        position: relative;
    }

    .input-wrap svg {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        width: 16px;
        height: 16px;
        color: #aaa;
        pointer-events: none;
    }

    .input-wrap input {
        width: 100%;
        padding: 12px 14px 12px 42px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        font-size: 14px;
        font-family: 'DM Sans', sans-serif;
        color: var(--dark);
        background: var(--white);
        outline: none;
        transition: border 0.2s;
    }

    .input-wrap input:focus {
        border-color: var(--dark);
    }

    .input-wrap .toggle-pw {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        pointer-events: all;
        color: #aaa;
    }

    .row-between {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .remember {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: var(--mid);
        cursor: pointer;
    }

    .remember input {
        accent-color: var(--dark);
    }

    .forgot {
        font-size: 13px;
        color: var(--red);
        text-decoration: none;
        font-weight: 500;
    }

    .btn-login {
        width: 100%;
        padding: 14px;
        background: var(--dark);
        color: var(--white);
        border: none;
        border-radius: var(--radius);
        font-size: 15px;
        font-family: 'DM Sans', sans-serif;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        margin-bottom: 16px;
    }

    .btn-login:hover {
        background: #333;
    }

    .btn-login:active {
        transform: scale(0.99);
    }

    .divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .divider::before,
    .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border);
    }

    .divider span {
        font-size: 12px;
        color: #bbb;
        white-space: nowrap;
    }

    .btn-google {
        width: 100%;
        padding: 13px;
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        font-size: 14px;
        font-family: 'DM Sans', sans-serif;
        color: var(--dark);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: border 0.2s, background 0.2s;
    }

    .btn-google:hover {
        background: var(--light);
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
        .left {
            display: none;
        }

        .right {
            padding: 32px 20px;
        }
    }
</style>

